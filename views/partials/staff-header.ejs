<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : '宣传品库存管理系统' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/staff">
        <i class="bi bi-box-seam"></i>
        <span class="d-none d-sm-inline">宣传品库存管理系统</span>
        <span class="d-inline d-sm-none">库存系统</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link <%= currentPage === 'dashboard' ? 'active' : '' %>" href="/staff">
              <i class="bi bi-house-door"></i> 工作台首页
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= currentPage === 'inventory' ? 'active' : '' %>" href="/staff/inventory">
              <i class="bi bi-box"></i> 库存管理
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= currentPage === 'usage' ? 'active' : '' %>" href="/staff/usage">
              <i class="bi bi-pencil-square"></i> 领用录入
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= currentPage === 'history' ? 'active' : '' %>" href="/staff/history">
              <i class="bi bi-clock-history"></i> 领用历史
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= currentPage === 'password' ? 'active' : '' %>" href="/staff/password">
              <i class="bi bi-key"></i> 密码管理
            </a>
          </li>
        </ul>
        <ul class="navbar-nav">
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i>
              <span class="d-none d-sm-inline"><%= user.name %></span>
              <span class="badge bg-light text-primary ms-1">二级人员</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/staff/password"><i class="bi bi-key"></i> 密码管理</a></li>
              <li><a class="dropdown-item" href="/logout"><i class="bi bi-box-arrow-right"></i> 退出登录</a></li>
            </ul>
          </li>
        </ul>
      </div>
    </div>
  </nav>
  <main class="container py-4">
