<%- include('../partials/staff-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-clock-history"></i> 领用历史</h2>
  <a href="/staff/export/usage?mode=<%= mode %>" class="btn btn-success"><i class="bi bi-file-earmark-excel"></i> 导出<%= mode === 'mine' ? '本人' : '本部门' %>明细报表</a>
</div>

<ul class="nav nav-tabs mb-4">
  <li class="nav-item"><a class="nav-link <%= mode === 'department' ? 'active' : '' %>" href="/staff/history?mode=department">本部门/网点明细报表</a></li>
  <li class="nav-item"><a class="nav-link <%= mode === 'mine' ? 'active' : '' %>" href="/staff/history?mode=mine">本人明细报表</a></li>
</ul>

<div class="card">
  <div class="card-body">
    <% if (records.length === 0) { %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-2 mb-0">暂无领用记录。</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>活动名称</th>
              <th>宣传品</th>
              <th>数量</th>
              <th>领用客户</th>
              <th>录入员工</th>
              <th>时间</th>
              <th>备注</th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(function(record) { %>
              <tr>
                <td><%= record.activity_name %></td>
                <td><strong><%= record.material_name %></strong></td>
                <td><span class="badge bg-primary"><%= record.quantity %> <%= record.unit %></span></td>
                <td><%= record.customer_name_masked || '-' %></td>
                <td><%= record.created_by_name %></td>
                <td><%= record.created_at %></td>
                <td><%= record.remark || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
