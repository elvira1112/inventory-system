<%- include('../partials/staff-header') %>

<h2 class="mb-4"><i class="bi bi-pencil-square"></i> 领用录入</h2>

<div class="row">
  <div class="col-12 col-lg-8">
    <div class="card">
      <div class="card-header"><i class="bi bi-plus-circle"></i> 新增领用记录</div>
      <div class="card-body">
        <% if (materials.length === 0) { %>
          <div class="alert alert-warning">暂无可领用的宣传品。</div>
        <% } else { %>
          <form method="POST" action="/staff/usage">
            <div class="mb-3">
              <label class="form-label">选择宣传品 <span class="text-danger">*</span></label>
              <select name="material_id" id="materialSelect" class="form-select" required>
                <option value="">-- 请选择 --</option>
                <% materials.forEach(function(m) { %>
                  <option value="<%= m.material_id %>" data-remaining="<%= m.remaining %>" data-unit="<%= m.unit %>">
                    【<%= m.activity_name %>】<%= m.material_name %>（可用 <%= m.remaining %> <%= m.unit %>）
                  </option>
                <% }); %>
              </select>
            </div>
            <div id="stockInfo" class="alert alert-info mb-3" style="display:none;">当前可用库存：<strong id="stockRemaining">0</strong> <span id="stockUnit"></span></div>
            <div class="mb-3">
              <label class="form-label">领用数量 <span class="text-danger">*</span></label>
              <input type="number" name="quantity" id="quantityInput" class="form-control" min="1" required>
            </div>
            <div class="mb-3">
              <label class="form-label">领用客户名称 <span class="text-danger">*</span></label>
              <input type="text" name="customer_name" class="form-control" required>
            </div>
            <div class="mb-4">
              <label class="form-label">备注</label>
              <textarea name="remark" class="form-control" rows="3"></textarea>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> 提交领用</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const select = document.getElementById('materialSelect');
  if (!select) return;
  const stockInfo = document.getElementById('stockInfo');
  const stockRemaining = document.getElementById('stockRemaining');
  const stockUnit = document.getElementById('stockUnit');
  const quantityInput = document.getElementById('quantityInput');
  select.addEventListener('change', function() {
    const selected = this.options[this.selectedIndex];
    stockRemaining.textContent = selected.dataset.remaining || 0;
    stockUnit.textContent = selected.dataset.unit || '';
    quantityInput.max = selected.dataset.remaining || 0;
    stockInfo.style.display = this.value ? 'block' : 'none';
  });
});
</script>

<%- include('../partials/footer') %>
