<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-send"></i> 宣传品分配</h2>
  <a href="/admin/inventory<%= selectedActivity ? '?activity_id=' + selectedActivity : '' %>" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> 返回库存</a>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/admin/allocations" class="row g-3 align-items-end">
      <div class="col-12 col-lg-9">
        <label class="form-label">选择活动</label>
        <select name="activity_id" class="form-select" onchange="this.form.submit()">
          <option value="">-- 请选择活动 --</option>
          <% activities.forEach(function(a) { %>
            <option value="<%= a.id %>" <%= selectedActivity == a.id ? 'selected' : '' %>><%= a.name %></option>
          <% }); %>
        </select>
      </div>
      <div class="col-12 col-lg-3"><button class="btn btn-outline-primary w-100">查询</button></div>
    </form>
  </div>
</div>

<% if (selectedActivity && materials.length > 0) { %>
  <div class="card">
    <div class="card-header"><i class="bi bi-table"></i> 各部门/网点宣传品分配</div>
    <div class="card-body">
      <form method="POST" action="/admin/allocations/update" onsubmit="setTimeout(function(){ alert('分配成功'); }, 50);">
        <input type="hidden" name="activity_id" value="<%= selectedActivity %>">
        <div class="table-responsive">
          <table class="table table-bordered align-middle">
            <thead class="table-light">
              <tr>
                <th>部门/网点</th>
                <% materials.forEach(function(m) { %>
                  <th class="text-center"><%= m.name %><br><small class="text-muted">总量 <%= m.total_quantity %> <%= m.unit %></small></th>
                <% }); %>
              </tr>
            </thead>
            <tbody>
              <% departments.forEach(function(dept) { %>
                <tr>
                  <td><strong><%= dept.name %></strong></td>
                  <% materials.forEach(function(m) { var alloc = allocations.find(function(a) { return a.department_id === dept.id && a.material_id === m.id; }) || {}; %>
                    <td>
                      <input type="number" class="form-control form-control-sm text-center" min="0"
                             name="allocations[dept_<%= dept.id %>_mat_<%= m.id %>]"
                             value="<%= alloc.allocated || 0 %>">
                      <small class="text-muted">已用 <%= alloc.used || 0 %>，已回收 <%= alloc.recovered || 0 %></small>
                    </td>
                  <% }); %>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <div class="text-end mt-3">
          <button type="submit" class="btn btn-primary btn-lg"><i class="bi bi-check-lg"></i> 确认分配</button>
        </div>
      </form>
    </div>
  </div>
<% } else if (selectedActivity) { %>
  <div class="alert alert-info">该活动暂无宣传品。</div>
<% } %>

<%- include('../partials/footer') %>
