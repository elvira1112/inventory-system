<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-calendar-event"></i> 活动管理</h2>
  <a href="/admin/template/activities" class="btn btn-outline-secondary">
    <i class="bi bi-download"></i> 下载模板
  </a>
</div>

<!-- 导入活动 -->
<div class="card mb-4">
  <div class="card-header">
    <i class="bi bi-upload"></i> 导入活动和宣传品
  </div>
  <div class="card-body">
    <form method="POST" action="/admin/activities/import" enctype="multipart/form-data" class="row g-3 align-items-end">
      <div class="col-md-8">
        <label class="form-label">选择Excel文件</label>
        <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required>
        <div class="form-text">需包含：活动名称、宣传品名称、数量、单位</div>
      </div>
      <div class="col-md-4">
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-upload"></i> 导入
        </button>
      </div>
    </form>
  </div>
</div>

<!-- 活动列表 -->
<div class="card">
  <div class="card-header">
    <i class="bi bi-list"></i> 活动列表
  </div>
  <div class="card-body">
    <% if (activities.length === 0) { %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-inbox fs-1"></i>
        <p>暂无活动，请导入</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>活动名称</th>
              <th>宣传品种类</th>
              <th>总数量</th>
              <th>创建时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% activities.forEach(function(a) { %>
              <tr>
                <td><%= a.id %></td>
                <td><strong><%= a.name %></strong></td>
                <td><span class="badge bg-primary"><%= a.material_count %> 种</span></td>
                <td><%= a.total_items %></td>
                <td><%= a.created_at %></td>
                <td>
                  <a href="/admin/activities/<%= a.id %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye"></i> 查看详情
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
