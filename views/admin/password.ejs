<%- include('../partials/admin-header') %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-7">
    <div class="card">
      <div class="card-header"><i class="bi bi-key"></i> 密码管理</div>
      <div class="card-body">
        <% if (first) { %>
          <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> 首次登录请先修改初始密码。</div>
        <% } %>
        <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
        <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
        <form method="POST" action="/admin/password">
          <div class="mb-3">
            <label class="form-label">原密码</label>
            <input type="password" class="form-control" name="old_password" required>
          </div>
          <div class="mb-3">
            <label class="form-label">新密码</label>
            <input type="password" class="form-control" name="new_password" required>
            <div class="form-text">规则：至少 6 位，不能是 4 位及以上重复数字，不能包含 3 位及以上连续数字，且不能与上一密码相同。</div>
          </div>
          <div class="mb-4">
            <label class="form-label">确认新密码</label>
            <input type="password" class="form-control" name="confirm_password" required>
          </div>
          <button class="btn btn-primary"><i class="bi bi-check-lg"></i> 修改密码</button>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
