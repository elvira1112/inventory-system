<%- include('../partials/admin-header') %>

<h2 class="mb-4"><i class="bi bi-house-door"></i> 工作台首页</h2>

<div class="row g-4 mb-4">
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 bg-primary text-white h-100">
      <div class="card-body">
        <div class="small opacity-75">部门/网点</div>
        <div class="display-6 fw-semibold"><%= stats.departmentCount %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 bg-success text-white h-100">
      <div class="card-body">
        <div class="small opacity-75">一级人员</div>
        <div class="display-6 fw-semibold"><%= stats.primaryUserCount %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 bg-info text-white h-100">
      <div class="card-body">
        <div class="small opacity-75">二级人员</div>
        <div class="display-6 fw-semibold"><%= stats.staffUserCount %></div>
      </div>
    </div>
  </div>
  <div class="col-6 col-lg-3">
    <div class="card stat-card border-0 bg-warning h-100">
      <div class="card-body">
        <div class="small text-muted">宣传品种类</div>
        <div class="display-6 fw-semibold"><%= stats.materialCount %></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-12 col-lg-6">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-grid"></i> 常用功能</div>
      <div class="card-body d-grid gap-2">
        <% if (user.role === 0) { %>
          <a href="/admin/users" class="btn btn-outline-primary"><i class="bi bi-people"></i> 人员权限管理</a>
          <a href="/admin/departments" class="btn btn-outline-primary"><i class="bi bi-building"></i> 部门/网点设置</a>
          <a href="/admin/inventory" class="btn btn-outline-success"><i class="bi bi-file-earmark-bar-graph"></i> 报表管理</a>
        <% } else { %>
          <a href="/admin/activities" class="btn btn-outline-primary"><i class="bi bi-calendar-event"></i> 活动管理</a>
          <a href="/admin/inventory" class="btn btn-outline-primary"><i class="bi bi-box"></i> 库存管理</a>
          <a href="/admin/password" class="btn btn-outline-primary"><i class="bi bi-key"></i> 密码管理</a>
        <% } %>
      </div>
    </div>
  </div>
  <div class="col-12 col-lg-6">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-info-circle"></i> 当前能力</div>
      <div class="card-body">
        <% if (user.role === 0) { %>
          <p class="mb-2">可以按部门/网点和活动筛选库存报表与明细报表，并按筛选结果导出。</p>
          <p class="mb-0 text-muted">库存总表与明细报表已支持合并单元格展示。</p>
        <% } else { %>
          <p class="mb-2">可进行活动导入、库存分配、回收登记，以及按活动导出库存报表和明细报表。</p>
          <% if (canDeleteActivities) { %>
            <p class="mb-0 text-muted">当前账号属于综合管理部，可删除未派发的活动。</p>
          <% } else { %>
            <p class="mb-0 text-muted">活动删除仅限综合管理部一级人员，且活动下宣传品未派发时才可删除。</p>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
