<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-box"></i> 库存概览</h2>
  <div class="action-buttons">
    <a href="/admin/export/inventory" class="btn btn-success">
      <i class="bi bi-file-earmark-excel"></i> <span class="d-none d-sm-inline">导出库存报表</span><span class="d-inline d-sm-none">库存</span>
    </a>
    <a href="/admin/export/usage" class="btn btn-outline-success">
      <i class="bi bi-file-earmark-excel"></i> <span class="d-none d-sm-inline">导出领用明细</span><span class="d-inline d-sm-none">明细</span>
    </a>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <% if (inventory.length === 0) { %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-inbox fs-1"></i>
        <p>暂无库存数据</p>
      </div>
    <% } else { %>
      <!-- 桌面版表格 -->
      <div class="table-responsive desktop-only">
        <table class="table table-hover">
          <thead class="table-light">
            <tr>
              <th>活动名称</th>
              <th>宣传品名称</th>
              <th>单位</th>
              <th>总数量</th>
              <th>已分配</th>
              <th>已使用</th>
              <th>未分配</th>
              <th>分配率</th>
            </tr>
          </thead>
          <tbody>
            <% inventory.forEach(function(item) { %>
              <% var rate = item.total_quantity > 0 ? Math.round(item.allocated / item.total_quantity * 100) : 0; %>
              <tr>
                <td><%= item.activity_name %></td>
                <td><strong><%= item.material_name %></strong></td>
                <td><%= item.unit %></td>
                <td><%= item.total_quantity %></td>
                <td><span class="badge bg-info"><%= item.allocated %></span></td>
                <td><span class="badge bg-warning text-dark"><%= item.used %></span></td>
                <td><span class="badge bg-success"><%= item.unallocated %></span></td>
                <td>
                  <div class="progress" style="width: 100px; height: 20px;">
                    <div class="progress-bar" role="progressbar" style="width: <%= rate %>%">
                      <%= rate %>%
                    </div>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 移动版卡片 -->
      <div class="mobile-only">
        <% inventory.forEach(function(item) { %>
          <% var rate = item.total_quantity > 0 ? Math.round(item.allocated / item.total_quantity * 100) : 0; %>
          <div class="table-mobile-card">
            <div class="mobile-row">
              <span class="mobile-label">活动:</span>
              <span class="mobile-value"><strong><%= item.activity_name %></strong></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">宣传品:</span>
              <span class="mobile-value"><%= item.material_name %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">单位:</span>
              <span class="mobile-value"><%= item.unit %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">总数量:</span>
              <span class="mobile-value"><%= item.total_quantity %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">已分配:</span>
              <span class="mobile-value"><span class="badge bg-info"><%= item.allocated %></span></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">已使用:</span>
              <span class="mobile-value"><span class="badge bg-warning text-dark"><%= item.used %></span></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">未分配:</span>
              <span class="mobile-value"><span class="badge bg-success"><%= item.unallocated %></span></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">分配率:</span>
              <span class="mobile-value">
                <div class="progress" style="width: 100%;">
                  <div class="progress-bar" role="progressbar" style="width: <%= rate %>%">
                    <%= rate %>%
                  </div>
                </div>
              </span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
