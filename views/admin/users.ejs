<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-people"></i> 人员管理</h2>
  <div>
    <a href="/admin/template/users" class="btn btn-outline-secondary">
      <i class="bi bi-download"></i> 下载模板
    </a>
  </div>
</div>

<div class="row g-4 mb-4">
  <!-- 导入人员 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-upload"></i> 导入人员名单
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/users/import" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">选择Excel文件</label>
            <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required>
            <div class="form-text">支持 .xlsx 格式，需包含：用户名、姓名、密码、部门/网点</div>
          </div>
          <button type="submit" class="btn btn-primary">
            <i class="bi bi-upload"></i> 导入
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- 添加单个用户 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-person-plus"></i> 添加单个用户
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/users/add">
          <div class="row g-2">
            <div class="col-6">
              <input type="text" class="form-control" name="username" placeholder="用户名" required>
            </div>
            <div class="col-6">
              <input type="text" class="form-control" name="name" placeholder="姓名" required>
            </div>
            <div class="col-6">
              <input type="password" class="form-control" name="password" placeholder="密码（默认123456）">
            </div>
            <div class="col-6">
              <select class="form-select" name="department_id" required>
                <option value="">选择部门</option>
                <% departments.forEach(function(dept) { %>
                  <option value="<%= dept.id %>"><%= dept.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-plus"></i> 添加
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- 用户列表 -->
<div class="card">
  <div class="card-header">
    <i class="bi bi-list"></i> 人员列表
  </div>
  <div class="card-body">
    <% if (users.length === 0) { %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-inbox fs-1"></i>
        <p>暂无二级人员，请导入或添加</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>用户名</th>
              <th>姓名</th>
              <th>部门/网点</th>
              <th>创建时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.name %></td>
                <td><%= u.department_name || '-' %></td>
                <td><%= u.created_at %></td>
                <td>
                  <form method="POST" action="/admin/users/delete/<%= u.id %>" style="display:inline"
                        onsubmit="return confirm('确定删除此用户？')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
