<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-people"></i> 人员管理</h2>
  <div class="action-buttons">
    <a href="/admin/template/users" class="btn btn-outline-secondary">
      <i class="bi bi-download"></i> <span class="d-none d-sm-inline">下载模板</span><span class="d-inline d-sm-none">模板</span>
    </a>
  </div>
</div>

<div class="row g-4 mb-4">
  <!-- 导入人员 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-upload"></i> 导入人员名单
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/users/import" enctype="multipart/form-data">
          <div class="mb-3">
            <label class="form-label">选择Excel文件</label>
            <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required>
            <div class="form-text">支持 .xlsx 格式，需包含：用户名、姓名、密码、部门/网点</div>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-upload"></i> 导入
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- 添加单个用户 -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-person-plus"></i> 添加单个用户
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/users/add">
          <div class="row g-2">
            <div class="col-12 col-sm-6">
              <input type="text" class="form-control" name="username" placeholder="用户名" required>
            </div>
            <div class="col-12 col-sm-6">
              <input type="text" class="form-control" name="name" placeholder="姓名" required>
            </div>
            <div class="col-12 col-sm-6">
              <input type="password" class="form-control" name="password" placeholder="密码（默认123456）">
            </div>
            <div class="col-12 col-sm-6">
              <select class="form-select" name="department_id" required>
                <option value="">选择部门</option>
                <% departments.forEach(function(dept) { %>
                  <option value="<%= dept.id %>"><%= dept.name %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary w-100">
                <i class="bi bi-plus"></i> 添加
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- 用户列表 -->
<div class="card">
  <div class="card-header">
    <i class="bi bi-list"></i> 人员列表
  </div>
  <div class="card-body">
    <% if (users.length === 0) { %>
      <div class="text-center text-muted py-4">
        <i class="bi bi-inbox fs-1"></i>
        <p>暂无二级人员，请导入或添加</p>
      </div>
    <% } else { %>
      <!-- 桌面版表格 -->
      <div class="table-responsive desktop-only">
        <table class="table table-hover">
          <thead>
            <tr>
              <th>ID</th>
              <th>用户名</th>
              <th>姓名</th>
              <th>部门/网点</th>
              <th>创建时间</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.name %></td>
                <td><%= u.department_name || '-' %></td>
                <td><%= u.created_at %></td>
                <td>
                  <form method="POST" action="/admin/users/delete/<%= u.id %>" style="display:inline"
                        onsubmit="return confirm('确定删除此用户？')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- 移动版卡片 -->
      <div class="mobile-only">
        <% users.forEach(function(u) { %>
          <div class="table-mobile-card">
            <div class="mobile-row">
              <span class="mobile-label">姓名:</span>
              <span class="mobile-value"><strong><%= u.name %></strong></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">用户名:</span>
              <span class="mobile-value"><%= u.username %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">部门:</span>
              <span class="mobile-value"><%= u.department_name || '-' %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">创建时间:</span>
              <span class="mobile-value"><%= u.created_at %></span>
            </div>
            <div class="mobile-row">
              <span class="mobile-label">操作:</span>
              <span class="mobile-value">
                <form method="POST" action="/admin/users/delete/<%= u.id %>" style="display:inline"
                      onsubmit="return confirm('确定删除此用户？')">
                  <button type="submit" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i> 删除
                  </button>
                </form>
              </span>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
