<%- include('../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1"><i class="bi bi-calendar-event"></i> <%= activity.name %></h2>
    <div class="text-muted">登记日期：<%= activity.registration_date || '-' %>　活动负责部门：<%= activity.department_name || '-' %></div>
  </div>
  <a href="/admin/activities" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> 返回</a>
</div>

<div class="card">
  <div class="card-header"><i class="bi bi-box"></i> 宣传品明细</div>
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead class="table-light">
          <tr>
            <th>宣传品名称</th>
            <th>总量</th>
            <th>当前已分配</th>
            <th>已领用</th>
            <th>已回收</th>
            <th>剩余可分配</th>
          </tr>
        </thead>
        <tbody>
          <% materials.forEach(function(material) { %>
            <tr>
              <td><strong><%= material.name %></strong></td>
              <td><%= material.total_quantity %></td>
              <td><%= material.allocated %></td>
              <td><%= material.used %></td>
              <td><%= material.recovered %></td>
              <td><span class="badge bg-success"><%= material.total_quantity - material.allocated %></span></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
